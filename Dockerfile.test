ARG BACKEND_IMAGE
FROM ${BACKEND_IMAGE}

COPY --chown=10001:10001 tests /app/tests

RUN python -m unittest discover -s /app/tests -v
RUN DATABASE_URL=sqlite:////tmp/cloud-migration-container-smoke.db \
    BACKEND_RBAC_ENFORCEMENT_ENABLED=false \
    ENTERPRISE_LICENSE_FILE= \
    ENTERPRISE_LICENSE_CACHE_FILE=/tmp/no-license-cache.json \
    python -c "import main; schema=main.app.openapi(); assert callable(main.health_ready); assert '/cloud-migration/execution/health' in schema['paths']; print('FastAPI route smoke: PASS')"
